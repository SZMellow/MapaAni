<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_nav"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.mapaani.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_nav_home"
            app:destination="@id/nav_home"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.mapaani.BuyerHomeFragment"
        android:label="buyer_home"
        tools:layout="@layout/buyer_home" />

    <fragment
        android:id="@+id/nav_orders"
        android:name="com.example.mapaani.OrdersFragment"
        android:label="active_orders"
        tools:layout="@layout/active_orders" />

    <fragment
        android:id="@+id/nav_support"
        android:name="com.example.mapaani.SupportFragment"
        android:label="support_screen"
        tools:layout="@layout/support_screen" />
    <fragment
        android:id="@+id/nav_favorites"
        android:name="com.example.mapaani.FavoritesFragment"
        android:label="favorites" />

    <fragment
        android:id="@+id/nav_list"
        android:name="com.example.mapaani.ListFragment"
        android:label="list" />
</navigation>