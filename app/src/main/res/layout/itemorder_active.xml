<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/itemImageIv"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/potatoes" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/itemNameTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Russet Potatoes"
            android:textColor="#3D2B2B"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/itemPriceTv"
            app:layout_constraintStart_toEndOf="@+id/itemImageIv"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/itemDateTimeTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="29 Nov, 01:20 pm"
            android:textColor="#999999"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@+id/itemNameTv"
            app:layout_constraintTop_toBottomOf="@+id/itemNameTv" />

        <TextView
            android:id="@+id/itemPriceTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱67.00"
            android:textColor="@color/Green2"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/itemCountTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 items"
            android:textColor="#999999"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/itemPriceTv" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/itemNameTv"
            app:layout_constraintTop_toBottomOf="@+id/itemDateTimeTv">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tab_selected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Cancel Order"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_selected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Track Driver"
                android:textColor="@color/black"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>